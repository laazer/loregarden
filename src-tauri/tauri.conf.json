{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loregarden",
  "version": "0.1.0",
  "identifier": "com.loregarden.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix client run dev -- --strictPort",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix client run build:vite-only",
    "frontendDist": "../client/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Loregarden — Agent SDLC",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../agent_context": "agent_context"
    },
    "externalBin": ["binaries/loregarden-backend"]
  }
}
